{
  "name": "@datafog/fogclaw",
  "version": "0.4.0",
  "description": "OpenClaw plugin for PII detection & custom entity redaction powered by DataFog",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "openclaw.plugin.json",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:plugin-smoke": "vitest run tests/plugin-smoke.test.ts",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "gliner": "^0.0.19",
    "onnxruntime-node": "1.19.2",
    "onnxruntime-web": "1.21.0",
    "sharp": "0.35.3",
    "typebox": "^1.1.39"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "openclaw": "^2026.6.11",
    "typescript": "^5.7.0",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=22.19.0"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "compat": {
      "pluginApi": ">=2026.3.24-beta.2"
    }
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/datafog/fogclaw.git"
  },
  "overrides": {
    "onnxruntime-web": "1.21.0",
    "sharp": "0.35.3"
  }
}
